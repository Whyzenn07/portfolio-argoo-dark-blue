# ══════════════════════════════════════════
# KONFIGURASI BACKEND PORTFOLIO
# Salin file ini menjadi .env lalu isi nilai-nilainya
# ══════════════════════════════════════════

# ─── PORT ───────────────────────────────
PORT=3001

# ─── Frontend URL (untuk CORS) ───────────
# Development:
FRONTEND_URL=http://localhost:5173
# Production (ganti dengan domain kamu):
# FRONTEND_URL=https://wahyu-argoo.dev

# ─── Gmail ──────────────────────────────
# Email Gmail kamu
GMAIL_USER=wahyuargomu123@gmail.com

# App Password Gmail (BUKAN password biasa!)
# Cara mendapatkan App Password:
#   1. Buka https://myaccount.google.com/security
#   2. Aktifkan "2-Step Verification" (jika belum)
#   3. Buka https://myaccount.google.com/apppasswords
#   4. Pilih app "Mail", device "Other (Custom)"
#   5. Ketik nama: "Portfolio Backend"
#   6. Salin 16 karakter password yang muncul
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── WhatsApp via CallMeBot ──────────────
# Nomor WhatsApp kamu (format: kode negara + nomor, tanpa + atau spasi)
# Contoh: 628122698390 (untuk +62 812-2698-390)
WA_PHONE=628122698390

# API Key dari CallMeBot
# Cara mendapatkan API Key:
#   1. Simpan nomor +34 644 35 12 85 di WhatsApp sebagai "CallMeBot"
#   2. Kirim pesan PERSIS ini ke CallMeBot:
#      "I allow callmebot to send me messages"
#   3. Tunggu balasan berisi API key (contoh: 1234567)
#   4. Salin API key tersebut di bawah ini
WA_APIKEY=1234567
